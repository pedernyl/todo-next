{
  "name": "todo-next-supabase",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "generate:admin-updates": "node scripts/generate-admin-updates-registry.mjs",
    "check:admin-updates-registry": "npm run -s generate:admin-updates && git diff --exit-code -- src/lib/adminUpdates/updates/registry.generated.ts",
    "predev": "npm run generate:admin-updates",
    "dev": "next dev",
    "prebuild": "npm run generate:admin-updates",
    "build": "next build",
    "pretest": "npm run generate:admin-updates",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.56.0",
    "marked": "^18.0.0",
    "next": "^16.0.7",
    "next-auth": "^4.24.11",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sanitize-html": "^2.17.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.56.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/ui": "^3.2.4",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "jsdom": "^27.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
